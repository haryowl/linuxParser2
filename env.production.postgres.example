# ===========================================
# GALI-PARSE POSTGRES PRODUCTION CONFIGURATION
# ===========================================
# Copy to env.production on the Postgres server:
#   cp env.production.postgres.example env.production
#   nano env.production

NODE_ENV=production

# New Postgres server
SERVER_IP=62.84.189.162
SERVER_DOMAIN=62.84.189.162

HTTP_PORT=8081
TCP_PORT=3003
FRONTEND_PORT=8080
MOBILE_PORT=3007

# PostgreSQL (required for this repo)
DB_DIALECT=postgres
DATABASE_URL=postgres://galiparse_user:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/galiparse
DB_SSL=false
DB_POOL_MAX=20

RECORD_RETENTION_ENABLED=false
RECORD_RETENTION_DAYS=365
TRACKING_MAX_POINTS=50000

VALIDATE_CHECKSUM=warn
ACK_AFTER_SAVE=false
FLUSH_ACK_TIMEOUT_MS=2000
MAX_PENDING_TELEMETRY=200

DASHBOARD_RECORDS_RANGE=1h
DASHBOARD_RECORDS_LIMIT=100

# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_JWT_SECRET
SESSION_SECRET=CHANGE_ME_SESSION_SECRET
BCRYPT_ROUNDS=12
COOKIE_SECURE=false

CORS_ORIGIN=http://62.84.189.162,http://62.84.189.162:8080,http://62.84.189.162:8081,http://62.84.189.162:3007

MAX_CONCURRENCY=4
BATCH_SIZE=100
LOG_LEVEL=info

AUTO_EXPORT_ENABLED=true
EXPORT_DIR=backend/exports
BACKUP_ENABLED=true
BACKUP_DIR=backups

RATE_LIMIT_ENABLED=true
PM2_INSTANCES=1
PM2_EXEC_MODE=fork
PM2_MAX_MEMORY_RESTART=2G

FRONTEND_BUILD_PATH=/opt/linuxParserPG/frontend/build
