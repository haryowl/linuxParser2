# ===========================================
# GALI-PARSE PRODUCTION CONFIGURATION
# ===========================================
# Copy this file to env.production and update with your values
# cp env.production.example env.production

# Environment
NODE_ENV=production

# Server Configuration
SERVER_IP=your-server-ip
SERVER_DOMAIN=your-domain.com

# Port Configuration
HTTP_PORT=8081
TCP_PORT=3003
FRONTEND_PORT=8080
MOBILE_PORT=3007

# Database Configuration
# sqlite (default) or postgres
DB_DIALECT=sqlite
DB_STORAGE=backend/data/prod.sqlite
DATABASE_URL=sqlite:backend/data/prod.sqlite
# For PostgreSQL:
# DB_DIALECT=postgres
# DATABASE_URL=postgres://user:password@localhost:5432/galiparse
# DB_SSL=false
# DB_POOL_MAX=10

# Record retention (disabled by default)
RECORD_RETENTION_ENABLED=false
RECORD_RETENTION_DAYS=365

# Tracking API point cap per request
TRACKING_MAX_POINTS=15000

# Galileosky packet CRC16-Modbus validation
# false = skip CRC check | warn (default) = log mismatch, still parse | strict = reject packet
VALIDATE_CHECKSUM=warn

# Send device ACK only after parse; optional short DB flush (default off for responsiveness)
# true = wait up to FLUSH_ACK_TIMEOUT_MS for batch save before ACK
ACK_AFTER_SAVE=false
FLUSH_ACK_TIMEOUT_MS=2000

# Max telemetry records to hold per TCP connection while waiting for IMEI tag 0x03
MAX_PENDING_TELEMETRY=200

# Dashboard/API default record window when range is not specified (bootstrap load)
DASHBOARD_RECORDS_RANGE=1h
DASHBOARD_RECORDS_LIMIT=100

# XTEA3 encryption key from device configurator (16 ASCII chars or 32 hex chars)
# Leave empty when devices do not use encryption
# GALILEOSKY_XTEA_KEY=

# Security Configuration
# ⚠️ IMPORTANT: Generate strong secrets using: openssl rand -hex 32
JWT_SECRET=your-super-secure-jwt-secret-key-change-this-in-production
SESSION_SECRET=your-super-secure-session-secret-key-change-this-in-production
BCRYPT_ROUNDS=12
# Set to true when serving the app over HTTPS (recommended behind nginx TLS)
COOKIE_SECURE=false

# CORS Configuration
CORS_ORIGIN=http://your-server-ip,http://your-server-ip:8080,http://your-server-ip:8081,http://your-server-ip:3007,http://your-domain.com

# Performance Configuration
MAX_CONCURRENCY=4
BATCH_SIZE=100
MAX_MEMORY_BUFFER=10485760
MAX_DISK_BUFFER=104857600

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=combined
LOG_FILE=logs/combined.log

# Export Configuration
AUTO_EXPORT_ENABLED=true
EXPORT_DIR=backend/exports
EXPORT_FORMAT=csv
EXPORT_RETENTION_DAYS=30

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_DIR=backups
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7

# Monitoring Configuration
HEALTH_CHECK_ENABLED=true
METRICS_ENABLED=true
METRICS_PORT=9090

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOGIN_WINDOW_MS=60000
RATE_LIMIT_LOGIN_MAX_REQUESTS=30
# Set RATE_LIMIT_ENABLED=false to disable the general /api limiter.

# PM2 Configuration
PM2_INSTANCES=1
PM2_EXEC_MODE=fork
PM2_MAX_MEMORY_RESTART=1G
PM2_MIN_UPTIME=10s
PM2_MAX_RESTARTS=10
PM2_RESTART_DELAY=4000

# Nginx Configuration (if using)
FRONTEND_BUILD_PATH=/opt/linuxParser2/frontend/build
MOBILE_FRONTEND_BUILD_PATH=/opt/linuxParser2/mobile-frontend/build
MAX_FILE_SIZE=10M
SSL_CERT_PATH=/etc/ssl/certs/gali-parse.crt
SSL_KEY_PATH=/etc/ssl/private/gali-parse.key


